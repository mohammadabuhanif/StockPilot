{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An item in the shop inventory.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the product." },
        "category": { "type": "string", "description": "The category of the product." },
        "price": { "type": "number", "description": "The selling price of the product." },
        "cost": { "type": "number", "description": "The cost price of the product." },
        "stock": { "type": "integer", "description": "The current stock level." },
        "minStock": { "type": "integer", "description": "The minimum stock level for alerts." },
        "imageUrl": { "type": "string", "description": "The URL of the product image." },
        "description": { "type": "string", "description": "A detailed description of the product." },
        "isFeatured": { "type": "boolean", "description": "Whether the product is featured on the shop." },
        "barcode": { "type": "string", "description": "The unique barcode of the product." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "The last time the product was updated." }
      },
      "required": ["name", "price", "cost", "stock", "minStock"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A record of a product sale.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "The ID of the product sold." },
        "productName": { "type": "string", "description": "The name of the product at the time of sale." },
        "quantity": { "type": "integer", "description": "The number of items sold." },
        "totalPrice": { "type": "number", "description": "The total selling price." },
        "totalProfit": { "type": "number", "description": "The total profit from the sale." },
        "timestamp": { "type": "string", "format": "date-time", "description": "The time of the sale." }
      },
      "required": ["productId", "productName", "quantity", "totalPrice", "totalProfit", "timestamp"]
    },
    "Note": {
      "title": "Note",
      "description": "A personal note or thought.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns the note." },
        "title": { "type": "string", "description": "The title of the note." },
        "content": { "type": "string", "description": "The content of the note (HTML/Rich Text)." },
        "color": { "type": "string", "description": "The theme color of the note." },
        "fontSize": { "type": "string", "description": "The font size of the note." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation time." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "The last update time." }
      },
      "required": ["userId", "title", "content", "createdAt", "updatedAt"]
    },
    "Idea": {
      "title": "Idea",
      "description": "A smart idea generated by AI or user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns the idea." },
        "content": { "type": "string", "description": "The content of the idea." },
        "source": { "type": "string", "description": "The source of the idea (ai/user)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation time." }
      },
      "required": ["userId", "content", "source", "createdAt"]
    },
    "Service": {
      "title": "Service",
      "description": "A service offered by the shop (e.g., Photo Print, Tax Application).",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the service." },
        "category": { "type": "string", "enum": ["printing", "document", "other"], "description": "The category of the service." },
        "basePrice": { "type": "number", "description": "The base price of the service." },
        "description": { "type": "string", "description": "A description of the service." }
      },
      "required": ["name", "category", "basePrice"]
    },
    "ServiceOrder": {
      "title": "ServiceOrder",
      "description": "An order for a specific service.",
      "type": "object",
      "properties": {
        "serviceId": { "type": "string", "description": "The ID of the service." },
        "serviceName": { "type": "string", "description": "The name of the service." },
        "customerName": { "type": "string", "description": "The name of the customer." },
        "customerPhone": { "type": "string", "description": "The phone number of the customer." },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "delivered"], "description": "The status of the order." },
        "price": { "type": "number", "description": "The agreed price for the service." },
        "notes": { "type": "string", "description": "Additional notes for the order." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation time." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "The last update time." }
      },
      "required": ["serviceId", "serviceName", "customerName", "customerPhone", "status", "price", "createdAt", "updatedAt"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A record of a shop expense.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the expense." },
        "category": { "type": "string", "enum": ["rent", "utilities", "supplies", "marketing", "other"], "description": "The category of the expense." },
        "amount": { "type": "number", "description": "The amount spent." },
        "date": { "type": "string", "format": "date-time", "description": "The date of the expense." },
        "note": { "type": "string", "description": "Additional notes." }
      },
      "required": ["title", "category", "amount", "date"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A record of a shop customer.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the customer." },
        "phone": { "type": "string", "description": "The phone number of the customer." },
        "email": { "type": "string", "description": "The email of the customer." },
        "totalSpent": { "type": "number", "description": "The total amount spent by the customer." },
        "loyaltyPoints": { "type": "integer", "description": "The loyalty points earned." },
        "notes": { "type": "string", "description": "Additional notes about the customer." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation time." },
        "lastVisit": { "type": "string", "format": "date-time", "description": "The last visit time." }
      },
      "required": ["name", "phone", "totalSpent", "loyaltyPoints", "createdAt", "lastVisit"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global shop settings and profile information.",
      "type": "object",
      "properties": {
        "shopName": { "type": "string", "description": "The name of the shop." },
        "shopAddress": { "type": "string", "description": "The address of the shop." },
        "shopPhone": { "type": "string", "description": "The contact phone number." },
        "shopEmail": { "type": "string", "description": "The contact email." },
        "memoFooter": { "type": "string", "description": "A custom message at the bottom of the memo." }
      },
      "required": ["shopName"]
    },
    "AppUser": {
      "title": "AppUser",
      "description": "A user of the application with specific roles and security PIN.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth ID." },
        "email": { "type": "string", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "role": { "type": "string", "enum": ["admin", "fixer", "staff"], "description": "The user's role." },
        "pin": { "type": "string", "description": "A 4-6 digit security PIN." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created." }
      },
      "required": ["uid", "email", "role", "displayName", "createdAt"]
    },
    "CashRegisterSession": {
      "title": "CashRegisterSession",
      "description": "A daily record of the physical cash register session.",
      "type": "object",
      "properties": {
        "registerId": { "type": "string", "enum": ["sales", "service", "fixer", "mfs"], "description": "The specific register/drawer." },
        "date": { "type": "string", "description": "The date of the record (YYYY-MM-DD)." },
        "status": { "type": "string", "enum": ["open", "closed"], "description": "Session status." },
        "openedAt": { "type": "string", "format": "date-time", "description": "Opening time." },
        "openedBy": { "type": "string", "description": "User ID who opened." },
        "openingBalance": { "type": "number", "description": "Initial cash in drawer." },
        "closedAt": { "type": "string", "format": "date-time", "description": "Closing time." },
        "closedBy": { "type": "string", "description": "User ID who closed." },
        "closingBalance": { "type": "number", "description": "Actual cash counted." },
        "expectedBalance": { "type": "number", "description": "System calculated cash." },
        "discrepancy": { "type": "number", "description": "Difference between actual and expected." },
        "closingImageUrl": { "type": "string", "description": "Photo proof of closing cash." },
        "notes": { "type": "string", "description": "Additional notes." }
      },
      "required": ["registerId", "date", "status", "openedAt", "openedBy", "openingBalance"]
    },
    "MFSTransaction": {
      "title": "MFSTransaction",
      "description": "A Mobile Financial Service transaction.",
      "type": "object",
      "properties": {
        "provider": { "type": "string", "enum": ["bkash", "nagad", "rocket", "recharge", "other"], "description": "The service provider." },
        "type": { "type": "string", "enum": ["cash_in", "cash_out", "send_money", "recharge"], "description": "The transaction type." },
        "amount": { "type": "number", "description": "The transaction amount." },
        "commission": { "type": "number", "description": "The commission earned." },
        "customerPhone": { "type": "string", "description": "The customer's phone number." },
        "notes": { "type": "string", "description": "Additional notes." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation time." }
      },
      "required": ["provider", "type", "amount", "commission", "customerPhone", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "AppUser",
      "description": "Collection of application users."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products in the inventory."
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Collection of sales records."
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "Collection of personal notes."
    },
    "/ideas/{ideaId}": {
      "schema": "Idea",
      "description": "Collection of smart ideas."
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Collection of services offered."
    },
    "/serviceOrders/{orderId}": {
      "schema": "ServiceOrder",
      "description": "Collection of service orders."
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Collection of shop expenses."
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Collection of shop customers."
    },
    "/cashRegisters/{sessionId}": {
      "schema": "CashRegisterSession",
      "description": "Collection of daily cash register sessions."
    },
    "/mfsTransactions/{txId}": {
      "schema": "MFSTransaction",
      "description": "Collection of MFS transactions."
    },
    "/settings/global": {
      "schema": "Settings",
      "description": "Global shop settings."
    }
  }
}
